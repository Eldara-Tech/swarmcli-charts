{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" }
      },
      "required": ["repository"]
    },
    "logging": {
      "type": "object",
      "properties": {
        "driver": { "type": "string" },
        "options": { "type": "object" }
      }
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "target": { "type": "integer" },
          "published": { "type": "integer" },
          "protocol": { "type": "string", "enum": ["tcp", "udp"] },
          "mode": { "type": "string", "enum": ["host", "ingress"] }
        },
        "required": ["target", "published"]
      }
    },
    "configs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "external": { "type": "boolean" }
        },
        "required": ["source", "target"]
      }
    },
    "traefik": {
      "type": "object",
      "properties": {
        "network": { "type": "string" },
        "constraintLabel": { "type": "string" },
        "extraEntrypoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "address": { "type": "string" }
            },
            "required": ["name", "address"]
          }
        },
        "certResolver": { "type": "string" },
        "trustedIPs": { "type": "array", "items": { "type": "string" } },
        "acme": {
          "type": "object",
          "properties": { "email": { "type": "string" } }
        },
        "hsts": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "stsSeconds": { "type": "integer", "minimum": 0 },
            "includeSubdomains": { "type": "boolean" },
            "preload": { "type": "boolean" },
            "forceSTSHeader": { "type": "boolean" }
          }
        },
        "dashboard": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "host": { "type": "string" },
            "insecure": { "type": "boolean" },
            "basicAuthUsers": { "type": "string" }
          }
        },
        "apiPort": { "type": "integer", "minimum": 1 },
        "bufferingMaxRequestBodyBytes": { "type": "integer", "minimum": 0 },
        "log": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "access": { "type": "boolean" },
            "level": { "type": "string" }
          }
        }
      }
    },
    "extraLabels": { "type": "object" },
    "extraCommands": { "type": "array", "items": { "type": "string" } }
  }
}

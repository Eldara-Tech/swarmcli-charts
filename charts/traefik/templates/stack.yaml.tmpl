version: "3.9"

services:

  traefik:
    image: {{ .Values.image.repository }}:{{ if .Values.image.tag }}{{ .Values.image.tag }}{{ else }}{{ .Chart.AppVersion }}{{ end }}

{{- if .Values.configs }}
    configs:
{{- range .Values.configs }}
      - source: {{ .source }}
        target: {{ .target }}
{{- end }}
{{- end }}

    ports:
{{- range .Values.ports }}
      - target: {{ .target }}
        published: {{ .published }}
        protocol: {{ .protocol | default "tcp" }}
        mode: {{ .mode | default "host" }}
{{- end }}

    deploy:
      placement:
        constraints:
{{- range .Values.deploy.placement.constraints }}
          - {{ . }}
{{- end }}

      labels:
        - "traefik.enable=true"
        - "traefik.swarm.network={{ .Values.traefik.network }}"
        - "traefik.constraint-label={{ .Values.traefik.constraintLabel }}"

{{- if .Values.traefik.hsts.enabled }}
        # HSTS middleware (applied globally on the https entrypoint below)
        - "traefik.http.middlewares.hsts-header.headers.stsSeconds={{ .Values.traefik.hsts.stsSeconds }}"
        - "traefik.http.middlewares.hsts-header.headers.stsIncludeSubdomains={{ .Values.traefik.hsts.includeSubdomains }}"
        - "traefik.http.middlewares.hsts-header.headers.stsPreload={{ .Values.traefik.hsts.preload }}"
        - "traefik.http.middlewares.hsts-header.headers.forceSTSHeader={{ .Values.traefik.hsts.forceSTSHeader }}"
{{- end }}

{{- if .Values.traefik.dashboard.enabled }}
{{- if .Values.traefik.dashboard.basicAuthUsers }}
        # Dashboard basic-auth middleware
        - "traefik.http.middlewares.admin-auth.basicauth.users={{ .Values.traefik.dashboard.basicAuthUsers }}"
{{- end }}

        # HTTP → HTTPS redirect middleware
        - "traefik.http.middlewares.https-redirect.redirectscheme.scheme=https"
        - "traefik.http.middlewares.https-redirect.redirectscheme.permanent=true"

        # Dashboard HTTP → HTTPS redirect
        - "traefik.http.routers.traefik-public-http.rule=Host(`{{ .Values.traefik.dashboard.host }}`)"
        - "traefik.http.routers.traefik-public-http.entrypoints=http"
        - "traefik.http.routers.traefik-public-http.middlewares=https-redirect"

        # Dashboard HTTPS
        - "traefik.http.routers.traefik-public-https.rule=Host(`{{ .Values.traefik.dashboard.host }}`)"
        - "traefik.http.routers.traefik-public-https.entrypoints=https"
        - "traefik.http.routers.traefik-public-https.tls=true"
        - "traefik.http.routers.traefik-public-https.tls.certresolver={{ .Values.traefik.certResolver }}"
        - "traefik.http.routers.traefik-public-https.service=api@internal"
{{- $mw := list }}
{{- if .Values.traefik.dashboard.basicAuthUsers }}{{ $mw = append $mw "admin-auth" }}{{- end }}
{{- if .Values.traefik.hsts.enabled }}{{ $mw = append $mw "hsts-header" }}{{- end }}
{{- if $mw }}
        - "traefik.http.routers.traefik-public-https.middlewares={{ join "," $mw }}"
{{- end }}

        # Service port (Traefik's internal API the dashboard load-balances to)
        - "traefik.http.services.traefik-public.loadbalancer.server.port={{ .Values.traefik.apiPort }}"
{{- end }}

{{- if .Values.traefik.bufferingMaxRequestBodyBytes }}
        # Request buffering
        - "traefik.http.middlewares.limit.buffering.maxRequestBodyBytes={{ .Values.traefik.bufferingMaxRequestBodyBytes }}"
{{- end }}

{{- if .Values.extraLabels }}
{{- range $key, $val := .Values.extraLabels }}
        - "{{ $key }}={{ $val }}"
{{- end }}
{{- end }}

    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - traefik-public-certificates:/certificates

    command:
      # Provider
      - --providers.swarm=true
      - --providers.swarm.constraints=Label(`traefik.constraint-label`, `{{ .Values.traefik.constraintLabel }}`)
      - --providers.swarm.exposedByDefault=false
{{- if .Values.configs }}
      - --providers.file.directory=/config
      - --providers.file.watch=false
{{- end }}

      # Entrypoints
      - --entrypoints.http.address=:80
      - --entrypoints.https.address=:443
{{- if .Values.traefik.hsts.enabled }}
      - --entrypoints.https.http.middlewares=hsts-header@swarm
{{- end }}

      # Trusted IPs
{{- range .Values.traefik.trustedIPs }}
      - --entrypoints.http.forwardedHeaders.trustedIPs={{ . }}
      - --entrypoints.https.forwardedHeaders.trustedIPs={{ . }}
      - --entrypoints.http.proxyProtocol.trustedIPs={{ . }}
      - --entrypoints.https.proxyProtocol.trustedIPs={{ . }}
{{- end }}

      # ACME / Let's Encrypt
      - --certificatesresolvers.{{ .Values.traefik.certResolver }}.acme.email={{ .Values.traefik.acme.email }}
      - --certificatesresolvers.{{ .Values.traefik.certResolver }}.acme.storage=/certificates/acme.json
      - --certificatesresolvers.{{ .Values.traefik.certResolver }}.acme.tlschallenge=true

      # Logging
      - --accesslog={{ .Values.traefik.log.access }}
      - --log={{ .Values.traefik.log.enabled }}
      - --log.level={{ .Values.traefik.log.level }}

      # API / Dashboard
      - --api={{ .Values.traefik.dashboard.enabled }}
{{- if .Values.traefik.dashboard.enabled }}
      - --api.dashboard=true
      - --api.insecure={{ .Values.traefik.dashboard.insecure }}
{{- end }}

{{- if .Values.extraCommands }}
{{- range .Values.extraCommands }}
      - {{ . }}
{{- end }}
{{- end }}

    networks:
      - {{ .Values.traefik.network }}

{{- if .Values.configs }}

configs:
{{- range .Values.configs }}
  {{ .source }}:
    external: {{ .external | default false }}
{{- end }}
{{- end }}

volumes:
  traefik-public-certificates:

networks:
  {{ .Values.traefik.network }}:
    external: true
